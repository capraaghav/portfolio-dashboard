# Copy this file to `.streamlit/secrets.toml` (which is gitignored) and fill in your
# Supabase project's values to enable email login + per-user cloud storage.
# Leave it absent to run the app locally with file-based storage and no login.
#
# Find these in your Supabase project: Settings → API.

SUPABASE_URL = "https://YOUR-PROJECT-ref.supabase.co"
SUPABASE_ANON_KEY = "YOUR-anon-public-key"

# Optional (only used when Supabase is NOT configured): per-session isolation on a
# shared local/hosted deployment.
# PORTFOLIO_MULTIUSER = "1"
